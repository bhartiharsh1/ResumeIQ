# ── Razorpay ──────────────────────────────────────────────────────────────────
# Get from: Razorpay Dashboard → Settings → Webhooks → Webhook Secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# The Gmail address that will SEND the code emails
GMAIL_USER=your_gmail@gmail.com
# App Password (NOT your Gmail login password)
# Get from: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── App URL ───────────────────────────────────────────────────────────────────
# Your deployed Streamlit app URL (for the email link)
APP_URL=https://resumeiq.streamlit.app
