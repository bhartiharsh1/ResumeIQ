{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd webhook_server && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd webhook_server && gunicorn app:app --bind 0.0.0.0:$PORT",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
