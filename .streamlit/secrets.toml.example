# Streamlit Cloud secrets — copy values into App Settings → Secrets (never commit this file)

OPENROUTER_API_KEY   = "your-openrouter-api-key-here"
APOLLO_API_KEY       = "your-apollo-api-key-here"

# Google OAuth 2.0 — create at console.cloud.google.com → APIs → Credentials
# Add authorized redirect URI: https://your-app.streamlit.app/
GOOGLE_CLIENT_ID     = "xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET = "GOCSPX-xxxx"

# Deployed app URL — must exactly match the redirect URI in Google Console
APP_URL              = "https://resumeiq.streamlit.app"
